node_modules/

# 构建输出目录
public/

# Hexo缓存
.hexo-deployer-git-cache
.hexo-renderer-stylus-cache

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 临时文件
.DS_Store
Thumbs.db

# 环境变量文件
.env
.env.local
.env.*.local

# IDE配置文件
.vscode/
.idea/
*.swp
*.swo
*~

# Vercel部署
.vercel

# 其他
.sass-cache/
*.bak
*.tmp
*.temp